---
import Layout from "@layouts/Layout.astro";
import TextScramble from "@components/TextScramble";
import { getCollection } from "astro:content";
import { defaultMeta } from "@data/constants";
import Blog from "@components/Blog.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout>
  <section class="text-center">
    <div class="grid place-items-center">
      <TextScramble
        text={defaultMeta.title}
        as="h1"
        className="mb-6 text-zinc-100 text-3xl font-bold tracking-tight sm:text-4xl text-center font-heading"
        duration={800}
        client:load
      />
      <p class="mt-3 max-w-prose leading-relaxed">
        {defaultMeta.description}
      </p>
    </div>
  </section>
  <section>
    <h2 class="mt-12 text-2xl font-semibold text-zinc-100 font-heading">
      recent posts
    </h2>
    <ul class="mt-6 grid grid-cols-1">
      {posts.slice(0, 3).map((post) => <Blog {...post} />)}
    </ul>
    <a
      class="inline-block mt-7 hover:text-zinc-50 transition-colors slide-underline"
      href="/blog/">View all posts &rarr;</a
    >
  </section>
</Layout>
